# Nuwa Pet · 开发期凭据
# 复制为 `.env.dev` 后填上真值，文件已在根 .gitignore 中，不会提交到仓库。
#
# 启动 `pnpm dev` 时，主进程会自动读取它：
#   - 把 LLM Provider 设为下方的值，跳过首启 Wizard 的 Provider 步骤
#   - 把 first-run 标记为完成，直接进入角色仓库
# 生产打包后不读 `.env.dev`，普通用户仍走标准 Wizard。
#
# 如果想强制走 Wizard，把整行注释掉或设 NUWA_PET_DEV_SKIP_SETUP=0。

NUWA_PET_DEV_SKIP_SETUP=1

# OpenAI 兼容协议（DeepSeek / Moonshot / SiliconFlow 等）
NUWA_PET_LLM_KIND=openai-compatible
NUWA_PET_LLM_BASE_URL=https://api.deepseek.com
NUWA_PET_LLM_MODEL=deepseek-v4-flash
NUWA_PET_LLM_API_KEY=sk-填你的-deepseek-key

# 参考图 vision 读图（与主模型分离；OhMyGPT 上推荐豆包 Seed 2.0 Lite）
NUWA_PET_VISION_MODEL=bytedance/doubao-seed-2.0-lite-260428
