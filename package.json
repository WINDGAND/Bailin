{
  "name": "bailin",
  "version": "0.0.1",
  "private": true,
  "description": "桌面上的百变魂灵 · 60 秒造人，像素桌宠常驻桌面，Ctrl+Shift+P 用 ta 的视角陪你思考 —— 完全本地，自带 Key",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build && pnpm --filter=./apps/desktop run build",
    "postinstall": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm --filter=./apps/desktop run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3"
  }
}
