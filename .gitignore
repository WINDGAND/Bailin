# Node / pnpm
node_modules/
.pnpm-store/

# Builds
dist/
build/
out/
.cache/
.turbo/

# Electron build artifacts
release/
apps/desktop/.pack-staging/
apps/desktop/pack-out/
apps/desktop/release/
*.exe
*.app
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.msi

# Vite / TS
*.tsbuildinfo
.vite/
# 主进程 tsc 输出在 dist/main；勿在 src/shared 留编译产物（会遮蔽 .ts 导致渲染白屏）
apps/desktop/src/shared/*.js
apps/desktop/src/shared/*.js.map
apps/desktop/src/shared/*.d.ts
apps/desktop/src/shared/*.d.ts.map

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Env / secrets
.env
.env.dev
.env.*.local
.env.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.cursor/

# Agent skills（本地安装缓存，锁文件见 skills-lock.json）
.agents/

# Local user vault (we never commit user data)
**/AppData/
**/NuwaPet/

# Test
coverage/
.smoke-out/

# Debug / smoke run artifacts（脚本本身受 git 管理，运行产物不进库）
scripts/debug/_*
scripts/verify/_*
