{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/renderer",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["vite/client"],
    "composite": false,
    "noEmit": true
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
