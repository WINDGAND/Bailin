{
  "name": "@bailin/pet-atlas-tools",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bailin/character-protocol": "workspace:*",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/pngjs": "^6.0.5",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3"
  }
}
